// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum DriverStatus {
  ACTIVE
  DAY_OFF
  VACATION
}

enum CarStatus {
  FREE
  MAINTENANCE
  BUSY
}

enum CarMaintenanceType {
  OIL_CHANGE
  FLUID_CHANGE
  INSPECTION
  REPAIR
  OTHER
}

enum TransferStatus {
  PLANNED
  COMPLETED
  CANCELLED
}

enum UserRole {
  ADMIN
  DISPATCHER
  DRIVER
}

enum WaybillStatus {
  DRAFT
  ISSUED
  CLOSED
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String
  role      UserRole @default(DISPATCHER)
  driverId  Int?     @unique
  driver    Driver?  @relation(fields: [driverId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transferHistory TransferHistory[]
  transferFilterPresets TransferFilterPreset[]
  createdWaybills Waybill[] @relation("WaybillCreatedBy")

  @@map("users")
}

model TransferFilterPreset {
  id        Int      @id @default(autoincrement())
  userId    Int
  name      String
  state     Json
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@map("transfer_filter_presets")
}

model Driver {
  id        Int          @id @default(autoincrement())
  fullName  String
  phone     String
  status    DriverStatus @default(ACTIVE)
  note      String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  transfers Transfer[]
  user      User?

  @@map("drivers")
}

model Car {
  id                           Int       @id @default(autoincrement())
  brand                        String
  model                        String
  plateNumber                  String    @unique
  status                       CarStatus @default(FREE)
  mileage                      Int       @default(0)
  nextServiceMileage           Int?
  lastServiceMileage           Int?
  lastServiceDate              DateTime?
  oilChangeMileage             Int?
  coolantChangeDate            DateTime?
  brakeFluidChangeDate         DateTime?
  transmissionFluidChangeDate  DateTime?
  isUnderRepair                Boolean   @default(false)
  repairNotes                  String?
  createdAt                    DateTime  @default(now())
  updatedAt                    DateTime  @updatedAt

  transfers Transfer[]
  maintenanceRecords CarMaintenance[]

  @@map("cars")
}

model CarMaintenance {
  id                        Int                @id @default(autoincrement())
  carId                     Int
  type                      CarMaintenanceType
  mileage                   Int
  performedAt               DateTime
  notes                     String?
  cost                      Float?
  oilChanged                Boolean            @default(false)
  coolantChanged            Boolean            @default(false)
  brakeFluidChanged         Boolean            @default(false)
  transmissionFluidChanged  Boolean            @default(false)
  createdAt                 DateTime           @default(now())

  car Car @relation(fields: [carId], references: [id], onDelete: Cascade)

  @@map("car_maintenance")
}

model Transfer {
  id          Int            @id @default(autoincrement())
  date        DateTime       @db.Date
  startTime   DateTime
  endTime     DateTime
  origin      String
  destination String
  clientName  String?
  clientPhone String?
  driverId    Int
  carId       Int
  status      TransferStatus @default(PLANNED)
  comment     String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  driver  Driver @relation(fields: [driverId], references: [id])
  car     Car    @relation(fields: [carId], references: [id])
  history TransferHistory[]
  waybill Waybill?

  @@map("transfers")
}

model Waybill {
  id                    Int           @id @default(autoincrement())
  number                String        @unique
  seriesBranchCode      String        @default("AST")
  seriesTypeCode        String        @default("TR")
  seriesMonth           String        @default("197001")
  transferId            Int           @unique
  createdById           Int?
  status                WaybillStatus @default(DRAFT)
  issueDate             DateTime
  validFrom             DateTime
  validTo               DateTime
  organizationName      String
  organizationBin       String?
  organizationAddress   String?
  dispatchAddress       String?
  driverName            String
  driverLicenseNumber   String?
  vehicleBrand          String
  vehicleModel          String
  vehiclePlateNumber    String
  route                 String
  odometerStart         Int?
  odometerEnd           Int?
  fuelType              String?
  fuelIssuedLiters      Float?
  fuelRemainingLiters   Float?
  mechanicName          String?
  medicName             String?
  preTripCheckPassed    Boolean?
  postTripCheckPassed   Boolean?
  preTripMedicalPassed  Boolean?
  postTripMedicalPassed Boolean?
  notes                 String?
  legalChecklist        Json?
  printedAt             DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  transfer Transfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  createdBy User?   @relation("WaybillCreatedBy", fields: [createdById], references: [id])

  @@index([issueDate])
  @@index([status])
  @@index([seriesBranchCode, seriesTypeCode, seriesMonth])
  @@map("waybills")
}

model TransferHistory {
  id          Int      @id @default(autoincrement())
  transferId  Int
  userId      Int
  action      String
  description String
  createdAt   DateTime @default(now())

  transfer Transfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id])

  @@map("transfer_history")
}
